+use super::*;
+
+pub use visual_elements::{GridLayout, Viewport};
+
+/// Layout manager that handles different layout algorithms and caching
+pub struct GridLayoutManager {
+    pub layout_algorithm: LayoutAlgorithm,
+    pub current_layout: GridLayout,
+    pub animation_progress: f32,
+}
+
+impl GridLayoutManager {
+    pub fn new() -> Self {
+        Self {
+            layout_algorithm: LayoutAlgorithm::ForceDirected(ForceDirectedConfig::default()),
+            current_layout: GridLayout::new(),
+            animation_progress: 1.0, // Fully loaded initially
+        }
+    }
+
+    pub fn calculate_layout(&mut self, call_graph: &core_data::CallGraph) {
+        match &self.layout_algorithm {
+            LayoutAlgorithm::ForceDirected(config) => {
+                let mut algorithm = ForceDirectedLayout::new(config.clone());
+                self.current_layout = algorithm.calculate_layout(call_graph);
+            }
+            LayoutAlgorithm::Grid(config) => {
+                let algorithm = GridLayoutAlgorithm::new(config.clone());
+                self.current_layout = algorithm.calculate_layout(call_graph);
+            }
+            LayoutAlgorithm::Hierarchical(config) => {
+                let mut algorithm = HierarchicalLayout::new(config.clone());
+                self.current_layout = algorithm.calculate_layout(call_graph);
+            }
+        }
+    }
+
+    pub fn set_algorithm(&mut self, algorithm: LayoutAlgorithm) {
+        self.layout_algorithm = algorithm;
+    }
+
+    pub fn get_layout(&self) -> &GridLayout {
+        &self.current_layout
+    }
+
+    pub fn get_layout_mut(&mut self) -> &mut GridLayout {
+        &mut self.current_layout
+    }
+}
+
+impl Default for GridLayoutManager {
+    fn default() -> Self {
+        Self::new()
+    }
+}
diff --git a/tui_ui/src/canvas/hierarchical_layout.rs b/tui_ui/src/canvas/hierarchical_layout.rs
new file mode 100644
index 0000000..c93afab
--- /dev/null
+++ b/tui_ui/src/canvas/hierarchical_layout.rs
@@ -0,0 +1,194 @@
+use super::*;
+use crate::canvas::graph_analysis::{analyze_call_hierarchy, find_root_nodes, calculate_node_importance};
+use core_data::{CallGraph, SymbolId};
+use ratatui::style::Color;
+
+/// Hierarchical layout implementation
+pub struct HierarchicalLayout {
+    config: HierarchicalConfig,
+    layers: Option<crate::canvas::graph_analysis::GraphLayers>,
+}
+
+impl HierarchicalLayout {
+    pub fn new(config: HierarchicalConfig) -> Self {
+        Self {
+            config,
+            layers: None,
+        }
+    }
+
+    pub fn calculate_layout(&mut self, call_graph: &CallGraph) -> GridLayout {
+        // Step 1: Analyze call hierarchy and assign layers
+        let root_nodes = self.find_root_nodes(call_graph);
+        self.layers = Some(analyze_call_hierarchy(call_graph, &root_nodes));
+        
+        // Step 2: Position nodes layer by layer
+        let mut layout = GridLayout::new();
+        
+        if let Some(ref layers) = self.layers {
+            for (layer_index, layer_nodes) in layers.layers.iter().enumerate() {
+                self.position_layer_nodes(&mut layout, call_graph, layer_index, layer_nodes);
+            }
+            
+            // Step 3: Add edges with proper routing
+            self.add_hierarchical_edges(&mut layout, call_graph);
+        }
+        
+        layout.center_viewport_on_bounds();
+        layout
+    }
+    
+    fn find_root_nodes(&self, call_graph: &CallGraph) -> Vec<SymbolId> {
+        let roots = find_root_nodes(call_graph);
+        
+        // If no clear roots found, pick the most important nodes
+        if roots.is_empty() && !call_graph.nodes.is_empty() {
+            let mut nodes_with_importance: Vec<_> = call_graph.nodes.keys()
+                .map(|id| (id, calculate_node_importance(call_graph, id)))
+                .collect();
+            
+            nodes_with_importance.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
+            
+            // Take top 20% as roots, but at least 1
+            let num_roots = (nodes_with_importance.len() / 5).max(1);
+            nodes_with_importance.into_iter()
+                .take(num_roots)
+                .map(|(id, _)| id.clone())
+                .collect()
+        } else {
+            roots
+        }
+    }
+    
+    fn position_layer_nodes(
+        &self,
+        layout: &mut GridLayout,
+        call_graph: &CallGraph,
+        layer_index: usize,
+        layer_nodes: &[SymbolId],
+    ) {
+        let (x, y_start) = self.calculate_layer_position(layer_index, layer_nodes.len());
+        
+        // Sort nodes in layer by importance for better positioning
+        let mut sorted_nodes: Vec<_> = layer_nodes.iter()
+            .map(|id| (id, calculate_node_importance(call_graph, id)))
+            .collect();
+        sorted_nodes.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
+        
+        for (node_index, (symbol_id, _)) in sorted_nodes.iter().enumerate() {
+            let y = y_start + node_index as f64 * self.config.node_spacing;
+            
+            let position = NodePosition::new(x, y);
+            let mut node = VisualNode::new((*symbol_id).clone(), position);
+            
+            // Set node properties
+            node.color = self.get_layer_color(layer_index);
+            node.width = self.calculate_node_width(call_graph, symbol_id);
+            node.height = 4.0; // Standard height
+            
+            layout.add_node(node);
+        }
+    }
+    
+    fn calculate_layer_position(&self, layer_index: usize, node_count: usize) -> (f64, f64) {
+        let x = match self.config.direction {
+            LayoutDirection::LeftRight => layer_index as f64 * self.config.layer_spacing,
+            LayoutDirection::RightLeft => -(layer_index as f64) * self.config.layer_spacing,
+            LayoutDirection::TopDown | LayoutDirection::BottomUp => 0.0, // Center horizontally
+        };
+        
+        let y = match self.config.direction {
+            LayoutDirection::TopDown => layer_index as f64 * self.config.layer_spacing,
+            LayoutDirection::BottomUp => -(layer_index as f64) * self.config.layer_spacing,
+            LayoutDirection::LeftRight | LayoutDirection::RightLeft => {
+                // Center vertically
+                let total_height = (node_count.saturating_sub(1)) as f64 * self.config.node_spacing;
+                -total_height / 2.0
+            }
+        };
+        
+        (x, y)
+    }
+    
+    fn get_layer_color(&self, layer_index: usize) -> Color {
+        // Color gradient based on layer depth
+        match layer_index % 6 {
+            0 => Color::Red,     // Entry points
+            1 => Color::Yellow,  // First level
+            2 => Color::Green,   // Second level
+            3 => Color::Blue,    // Third level
+            4 => Color::Magenta, // Fourth level
+            _ => Color::Cyan,    // Deeper levels
+        }
+    }
+    
+    fn calculate_node_width(&self, call_graph: &CallGraph, symbol_id: &SymbolId) -> f64 {
+        if let Some(function_node) = call_graph.nodes.get(symbol_id) {
+            // Base width on function name length
+            let name_length = function_node.name.len() as f64;
+            (name_length * 0.8 + 4.0).min(20.0).max(6.0)
+        } else {
+            8.0 // Default width
+        }
+    }
+    
+    fn add_hierarchical_edges(&self, layout: &mut GridLayout, call_graph: &CallGraph) {
+        for edge in &call_graph.edges {
+            if layout.nodes.contains_key(&edge.caller) && layout.nodes.contains_key(&edge.callee) {
+                let visual_edge = VisualEdge::new(
+                    edge.caller.clone(),
+                    edge.callee.clone(),
+                    EdgeType::Call,
+                ).with_color(self.get_edge_color(&edge.caller, &edge.callee, layout));
+                
+                layout.add_edge(visual_edge);
+            }
+        }
+    }
+    
+    fn get_edge_color(
+        &self,
+        from_symbol: &SymbolId,
+        to_symbol: &SymbolId,
+        layout: &GridLayout,
+    ) -> Color {
+        // Color edges based on the direction relative to layout flow
+        if let (Some(from_node), Some(to_node)) = (
+            layout.nodes.get(from_symbol),
+            layout.nodes.get(to_symbol),
+        ) {
+            match self.config.direction {
+                LayoutDirection::LeftRight => {
+                    if to_node.position.x > from_node.position.x {
+                        Color::Green // Forward edge
+                    } else {
+                        Color::Red // Back edge (potential cycle)
+                    }
+                }
+                LayoutDirection::RightLeft => {
+                    if to_node.position.x < from_node.position.x {
+                        Color::Green // Forward edge
+                    } else {
+                        Color::Red // Back edge
+                    }
+                }
+                LayoutDirection::TopDown => {
+                    if to_node.position.y > from_node.position.y {
+                        Color::Green // Forward edge
+                    } else {
+                        Color::Red // Back edge
+                    }
+                }
+                LayoutDirection::BottomUp => {
+                    if to_node.position.y < from_node.position.y {
+                        Color::Green // Forward edge
+                    } else {
+                        Color::Red // Back edge
+                    }
+                }
+            }
+        } else {
+            Color::Gray // Default
+        }
+    }
+}
diff --git a/tui_ui/src/canvas/layout_algorithms.rs b/tui_ui/src/canvas/layout_algorithms.rs
new file mode 100644
index 0000000..0fd8363
--- /dev/null
+++ b/tui_ui/src/canvas/layout_algorithms.rs
@@ -0,0 +1,276 @@
+use super::*;
+use crate::geometry::Vector2D;
+use core_data::{CallGraph, SymbolId};
+use ratatui::style::Color;
+use std::collections::HashMap;
+
+/// Different layout algorithms available
+#[derive(Debug, Clone, PartialEq)]
+pub enum LayoutAlgorithm {
+    ForceDirected(ForceDirectedConfig),
+    Hierarchical(HierarchicalConfig),
+    Grid(GridConfig),
+}
+
+/// Configuration for force-directed layout
+#[derive(Debug, Clone, PartialEq)]
+pub struct ForceDirectedConfig {
+    pub repulsion_strength: f32,
+    pub attraction_strength: f32,
+    pub damping: f32,
+    pub max_iterations: usize,
+    pub convergence_threshold: f32,
+}
+
+impl Default for ForceDirectedConfig {
+    fn default() -> Self {
+        Self {
+            repulsion_strength: 1000.0,
+            attraction_strength: 0.1,
+            damping: 0.9,
+            max_iterations: 100,
+            convergence_threshold: 1.0,
+        }
+    }
+}
+
+/// Configuration for hierarchical layout
+#[derive(Debug, Clone, PartialEq)]
+pub struct HierarchicalConfig {
+    pub layer_spacing: f64,
+    pub node_spacing: f64,
+    pub direction: LayoutDirection,
+}
+
+#[derive(Debug, Clone, PartialEq)]
+pub enum LayoutDirection {
+    TopDown,
+    BottomUp,
+    LeftRight,
+    RightLeft,
+}
+
+impl Default for HierarchicalConfig {
+    fn default() -> Self {
+        Self {
+            layer_spacing: 50.0,
+            node_spacing: 30.0,
+            direction: LayoutDirection::TopDown,
+        }
+    }
+}
+
+/// Configuration for grid layout
+#[derive(Debug, Clone, PartialEq)]
+pub struct GridConfig {
+    pub spacing: f64,
+    pub columns: Option<usize>, // None for auto-calculate
+}
+
+impl Default for GridConfig {
+    fn default() -> Self {
+        Self {
+            spacing: 20.0,
+            columns: None,
+        }
+    }
+}
+
+/// Force-directed layout implementation
+pub struct ForceDirectedLayout {
+    config: ForceDirectedConfig,
+    node_forces: HashMap<SymbolId, Vector2D>,
+    iteration_count: usize,
+}
+
+impl ForceDirectedLayout {
+    pub fn new(config: ForceDirectedConfig) -> Self {
+        Self {
+            config,
+            node_forces: HashMap::new(),
+            iteration_count: 0,
+        }
+    }
+
+    pub fn calculate_layout(&mut self, call_graph: &CallGraph) -> GridLayout {
+        let mut layout = self.initialize_layout(call_graph);
+        
+        for _ in 0..self.config.max_iterations {
+            self.calculate_forces(&layout, call_graph);
+            self.apply_forces(&mut layout);
+            
+            if self.forces_converged() {
+                break;
+            }
+        }
+        
+        layout.center_viewport_on_bounds();
+        layout
+    }
+
+    fn initialize_layout(&self, call_graph: &CallGraph) -> GridLayout {
+        let mut layout = GridLayout::new();
+        
+        // Place nodes in a circle initially
+        let node_count = call_graph.nodes.len();
+        let radius = (node_count as f64 * 10.0).sqrt();
+        
+        for (i, symbol_id) in call_graph.nodes.keys().enumerate() {
+            let angle = 2.0 * std::f64::consts::PI * i as f64 / node_count as f64;
+            let x = radius * angle.cos();
+            let y = radius * angle.sin();
+            
+            let position = NodePosition::new(x, y);
+            let mut node = VisualNode::new(symbol_id.clone(), position);
+            
+            // Color based on node type or properties
+            node.color = if call_graph.get_callees(symbol_id).is_empty() {
+                Color::Green // Leaf nodes
+            } else if call_graph.get_callers(symbol_id).is_empty() {
+                Color::Red // Root nodes
+            } else {
+                Color::Blue // Intermediate nodes
+            };
+            
+            layout.add_node(node);
+        }
+
+        // Add edges
+        for edge in &call_graph.edges {
+            let visual_edge = VisualEdge::new(
+                edge.caller.clone(),
+                edge.callee.clone(),
+                EdgeType::Call,
+            ).with_color(Color::Gray);
+            
+            layout.add_edge(visual_edge);
+        }
+
+        layout
+    }
+
+    fn calculate_forces(&mut self, layout: &GridLayout, call_graph: &CallGraph) {
+        // Clear previous forces
+        self.node_forces.clear();
+
+        // Calculate repulsive forces between all nodes
+        for (id1, node1) in &layout.nodes {
+            for (id2, node2) in &layout.nodes {
+                if id1 != id2 {
+                    let repulsion = self.calculate_repulsion(&node1.position, &node2.position);
+                    *self.node_forces.entry(id1.clone()).or_insert(Vector2D::zero()) = 
+                        self.node_forces.get(id1).unwrap_or(&Vector2D::zero()).add(&repulsion);
+                }
+            }
+        }
+
+        // Calculate attractive forces along edges
+        for edge in &call_graph.edges {
+            if let (Some(from_node), Some(to_node)) = (
+                layout.nodes.get(&edge.caller),
+                layout.nodes.get(&edge.callee),
+            ) {
+                let attraction = self.calculate_attraction(&from_node.position, &to_node.position);
+                
+                *self.node_forces.entry(edge.caller.clone()).or_insert(Vector2D::zero()) =
+                    self.node_forces.get(&edge.caller).unwrap_or(&Vector2D::zero()).add(&attraction);
+                
+                *self.node_forces.entry(edge.callee.clone()).or_insert(Vector2D::zero()) =
+                    self.node_forces.get(&edge.callee).unwrap_or(&Vector2D::zero()).subtract(&attraction);
+            }
+        }
+    }
+
+    fn calculate_repulsion(&self, pos1: &NodePosition, pos2: &NodePosition) -> Vector2D {
+        let dx = pos1.x - pos2.x;
+        let dy = pos1.y - pos2.y;
+        let distance = (dx * dx + dy * dy).sqrt().max(1.0);
+        
+        let force_magnitude = self.config.repulsion_strength as f64 / (distance * distance);
+        let direction = Vector2D::new(dx, dy).normalize();
+        
+        direction.scale(force_magnitude)
+    }
+
+    fn calculate_attraction(&self, pos1: &NodePosition, pos2: &NodePosition) -> Vector2D {
+        let dx = pos2.x - pos1.x;
+        let dy = pos2.y - pos1.y;
+        let distance = (dx * dx + dy * dy).sqrt();
+        
+        let force_magnitude = self.config.attraction_strength as f64 * distance;
+        let direction = Vector2D::new(dx, dy).normalize();
+        
+        direction.scale(force_magnitude)
+    }
+
+    fn apply_forces(&mut self, layout: &mut GridLayout) {
+        for (symbol_id, force) in &self.node_forces {
+            if let Some(node) = layout.get_node_mut(symbol_id) {
+                // Apply damping
+                let damped_force = force.scale(self.config.damping as f64);
+                
+                // Update position
+                node.position.x += damped_force.x;
+                node.position.y += damped_force.y;
+            }
+        }
+        
+        layout.update_bounds();
+    }
+
+    fn forces_converged(&self) -> bool {
+        let total_force: f64 = self.node_forces
+            .values()
+            .map(|force| force.magnitude())
+            .sum();
+        
+        total_force < self.config.convergence_threshold as f64
+    }
+}
+
+/// Grid layout implementation (simple, fast)
+pub struct GridLayoutAlgorithm {
+    config: GridConfig,
+}
+
+impl GridLayoutAlgorithm {
+    pub fn new(config: GridConfig) -> Self {
+        Self { config }
+    }
+
+    pub fn calculate_layout(&self, call_graph: &CallGraph) -> GridLayout {
+        let mut layout = GridLayout::new();
+        
+        let node_ids: Vec<_> = call_graph.nodes.keys().cloned().collect();
+        let node_count = node_ids.len();
+        
+        let columns = self.config.columns.unwrap_or_else(|| {
+            (node_count as f64).sqrt().ceil() as usize
+        });
+        
+        for (i, symbol_id) in node_ids.iter().enumerate() {
+            let row = i / columns;
+            let col = i % columns;
+            
+            let x = col as f64 * self.config.spacing;
+            let y = row as f64 * self.config.spacing;
+            
+            let position = NodePosition::new(x, y);
+            let node = VisualNode::new(symbol_id.clone(), position);
+            layout.add_node(node);
+        }
+
+        // Add edges
+        for edge in &call_graph.edges {
+            let visual_edge = VisualEdge::new(
+                edge.caller.clone(),
+                edge.callee.clone(),
+                EdgeType::Call,
+            );
+            layout.add_edge(visual_edge);
+        }
+
+        layout.center_viewport_on_bounds();
+        layout
+    }
+}
