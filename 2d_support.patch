@@ -0,0 +1,120 @@
+use super::*;
+use core_data::CallGraph;
+use ratatui::{
+    layout::{Alignment, Rect},
+    style::Style,
+    widgets::Paragraph,
+    Frame,
+};
+
+/// Text overlay information for rendering outside canvas
+#[derive(Debug, Clone)]
+pub struct TextOverlay {
+    pub text: String,
+    pub world_x: f64,
+    pub world_y: f64,
+    pub style: Style,
+}
+
+/// Calculate text overlay positions for all visible nodes
+pub fn calculate_text_overlays(
+    layout: &GridLayout,
+    call_graph: &CallGraph,
+    viewport: &Viewport,
+    area: Rect,
+) -> Vec<(TextOverlay, Rect)> {
+    let mut overlays = Vec::new();
+    
+    // Calculate visible bounds
+    let view_width = area.width as f64 / viewport.zoom_level;
+    let view_height = area.height as f64 / viewport.zoom_level;
+    let left = viewport.center_x - view_width / 2.0;
+    let right = viewport.center_x + view_width / 2.0;
+    let top = viewport.center_y - view_height / 2.0;
+    let bottom = viewport.center_y + view_height / 2.0;
+    
+    for (symbol_id, visual_node) in &layout.nodes {
+        // Check if node is visible
+        if visual_node.position.x >= left && visual_node.position.x <= right
+            && visual_node.position.y >= top && visual_node.position.y <= bottom
+        {
+            // Get function name from call graph
+            if let Some(function_node) = call_graph.nodes.get(symbol_id) {
+                let text = truncate_function_name(&function_node.name, viewport.zoom_level);
+                
+                // Convert world coordinates to screen coordinates
+                let screen_x = ((visual_node.position.x - left) / view_width * area.width as f64) as u16;
+                let screen_y = ((visual_node.position.y - top) / view_height * area.height as f64) as u16;
+                
+                // Calculate text area (ensure it fits within screen bounds)
+                let text_width = text.len().min(area.width as usize - screen_x as usize) as u16;
+                let text_height = 1u16;
+                
+                if screen_x < area.width && screen_y < area.height && text_width > 0 {
+                    let text_area = Rect {
+                        x: area.x + screen_x.saturating_sub(text_width / 2),
+                        y: area.y + screen_y,
+                        width: text_width,
+                        height: text_height,
+                    };
+                    
+                    let overlay = TextOverlay {
+                        text,
+                        world_x: visual_node.position.x,
+                        world_y: visual_node.position.y,
+                        style: get_text_style(visual_node, Some(symbol_id) == layout.get_selected_node()),
+                    };
+                    
+                    overlays.push((overlay, text_area));
+                }
+            }
+        }
+    }
+    
+    overlays
+}
+
+/// Render text overlays on top of the canvas
+pub fn render_text_overlays(f: &mut Frame, overlays: Vec<(TextOverlay, Rect)>) {
+    for (overlay, text_area) in overlays {
+        let paragraph = Paragraph::new(overlay.text)
+            .style(overlay.style)
+            .alignment(Alignment::Center);
+        f.render_widget(paragraph, text_area);
+    }
+}
+
+/// Truncate function name based on zoom level
+fn truncate_function_name(name: &str, zoom_level: f64) -> String {
+    let max_length = if zoom_level > 2.0 {
+        20
+    } else if zoom_level > 1.0 {
+        12
+    } else if zoom_level > 0.5 {
+        8
+    } else {
+        4
+    };
+    
+    if name.len() <= max_length {
+        name.to_string()
+    } else {
+        format!("{}…", &name[..max_length.saturating_sub(1)])
+    }
+}
+
+/// Get text style based on node state
+fn get_text_style(visual_node: &VisualNode, is_selected: bool) -> Style {
+    if is_selected || visual_node.is_selected {
+        Style::default()
+            .fg(ratatui::style::Color::Black)
+            .bg(ratatui::style::Color::Yellow)
+    } else if visual_node.is_highlighted {
+        Style::default()
+            .fg(ratatui::style::Color::White)
+            .bg(ratatui::style::Color::Blue)
+    } else {
+        Style::default()
+            .fg(ratatui::style::Color::White)
+    }
+}
