+use core_data::{CallGraph, SymbolId};
+use std::collections::{HashMap, HashSet, VecDeque};
+
+/// Graph layers for hierarchical layout
+#[derive(Debug, Clone)]
+pub struct GraphLayers {
+    pub layers: Vec<Vec<SymbolId>>,
+    pub max_layer: usize,
+    pub layer_map: HashMap<SymbolId, usize>,
+}
+
+impl GraphLayers {
+    pub fn new() -> Self {
+        Self {
+            layers: Vec::new(),
+            max_layer: 0,
+            layer_map: HashMap::new(),
+        }
+    }
+    
+    pub fn get_layer(&self, symbol_id: &SymbolId) -> Option<usize> {
+        self.layer_map.get(symbol_id).copied()
+    }
+    
+    pub fn add_to_layer(&mut self, symbol_id: SymbolId, layer: usize) {
+        // Ensure we have enough layers
+        while self.layers.len() <= layer {
+            self.layers.push(Vec::new());
+        }
+        
+        self.layers[layer].push(symbol_id.clone());
+        self.layer_map.insert(symbol_id, layer);
+        self.max_layer = self.max_layer.max(layer);
+    }
+}
+
+/// Analyze call hierarchy and assign nodes to layers
+pub fn analyze_call_hierarchy(call_graph: &CallGraph, root_nodes: &[SymbolId]) -> GraphLayers {
+    let mut layers = GraphLayers::new();
+    let mut visited = HashSet::new();
+    let mut queue = VecDeque::new();
+    
+    // Start with root nodes at layer 0
+    for root_id in root_nodes {
+        if call_graph.nodes.contains_key(root_id) {
+            queue.push_back((root_id.clone(), 0));
+        }
+    }
+    
+    // If no root nodes found, use all nodes with no incoming calls
+    if queue.is_empty() {
+        let roots = find_root_nodes(call_graph);
+        for root_id in roots {
+            queue.push_back((root_id, 0));
+        }
+    }
+    
+    // If still no roots (circular graph), pick any node
+    if queue.is_empty() && !call_graph.nodes.is_empty() {
+        if let Some(first_node) = call_graph.nodes.keys().next() {
+            queue.push_back((first_node.clone(), 0));
+        }
+    }
+    
+    // Breadth-first traversal to assign layers
+    while let Some((symbol_id, layer)) = queue.pop_front() {
+        if visited.contains(&symbol_id) {
+            continue;
+        }
+        
+        visited.insert(symbol_id.clone());
+        layers.add_to_layer(symbol_id.clone(), layer);
+        
+        // Add callees to next layer
+        let callees = call_graph.get_callees(&symbol_id);
+        for callee in callees {
+            if !visited.contains(&callee.id) {
+                queue.push_back((callee.id.clone(), layer + 1));
+            }
+        }
+    }
+    
+    // Handle any remaining unvisited nodes (disconnected components)
+    for symbol_id in call_graph.nodes.keys() {
+        if !visited.contains(symbol_id) {
+            layers.add_to_layer(symbol_id.clone(), layers.max_layer + 1);
+        }
+    }
+    
+    layers
+}
+
+/// Find root nodes (nodes with no incoming calls)
+pub fn find_root_nodes(call_graph: &CallGraph) -> Vec<SymbolId> {
+    let mut has_incoming = HashSet::new();
+    
+    // Mark all nodes that have incoming calls
+    for edge in &call_graph.edges {
+        has_incoming.insert(&edge.callee);
+    }
+    
+    // Find nodes with no incoming calls
+    call_graph
+        .nodes
+        .keys()
+        .filter(|id| !has_incoming.contains(id))
+        .cloned()
+        .collect()
+}
+
+/// Detect strongly connected components (cycles)
+pub fn detect_cycles(call_graph: &CallGraph) -> Vec<Vec<SymbolId>> {
+    let mut index_counter = 0;
+    let mut stack = Vec::new();
+    let mut indices = HashMap::new();
+    let mut lowlinks = HashMap::new();
+    let mut on_stack = HashSet::new();
+    let mut sccs = Vec::new();
+    
+    for node_id in call_graph.nodes.keys() {
+        if !indices.contains_key(node_id) {
+            tarjan_strongconnect(
+                node_id,
+                call_graph,
+                &mut index_counter,
+                &mut stack,
+                &mut indices,
+                &mut lowlinks,
+                &mut on_stack,
+                &mut sccs,
+            );
+        }
+    }
+    
+    // Filter out single-node SCCs (unless they have self-loops)
+    sccs.into_iter()
+        .filter(|scc| {
+            scc.len() > 1 || 
+            (scc.len() == 1 && call_graph.edges.iter().any(|e| e.caller == scc[0] && e.callee == scc[0]))
+        })
+        .collect()
+}
+
+/// Tarjan's algorithm for finding strongly connected components
+fn tarjan_strongconnect(
+    v: &SymbolId,
+    call_graph: &CallGraph,
+    index_counter: &mut usize,
+    stack: &mut Vec<SymbolId>,
+    indices: &mut HashMap<SymbolId, usize>,
+    lowlinks: &mut HashMap<SymbolId, usize>,
+    on_stack: &mut HashSet<SymbolId>,
+    sccs: &mut Vec<Vec<SymbolId>>,
+) {
+    indices.insert(v.clone(), *index_counter);
+    lowlinks.insert(v.clone(), *index_counter);
+    *index_counter += 1;
+    stack.push(v.clone());
+    on_stack.insert(v.clone());
+    
+    // Consider successors of v
+    let callees = call_graph.get_callees(v);
+    for callee in callees {
+        let w = &callee.id;
+        
+        if !indices.contains_key(w) {
+            // Successor w has not yet been visited; recurse on it
+            tarjan_strongconnect(
+                w,
+                call_graph,
+                index_counter,
+                stack,
+                indices,
+                lowlinks,
+                on_stack,
+                sccs,
+            );
+            lowlinks.insert(v.clone(), lowlinks[v].min(lowlinks[w]));
+        } else if on_stack.contains(w) {
+            // Successor w is in stack and hence in the current SCC
+            lowlinks.insert(v.clone(), lowlinks[v].min(indices[w]));
+        }
+    }
+    
+    // If v is a root node, pop the stack and create an SCC
+    if lowlinks[v] == indices[v] {
+        let mut scc = Vec::new();
+        loop {
+            let w = stack.pop().unwrap();
+            on_stack.remove(&w);
+            scc.push(w.clone());
+            if w == *v {
+                break;
+            }
+        }
+        sccs.push(scc);
+    }
+}
+
+/// Calculate node importance for layout prioritization
+pub fn calculate_node_importance(call_graph: &CallGraph, symbol_id: &SymbolId) -> f64 {
+    let incoming_count = call_graph.get_callers(symbol_id).len() as f64;
+    let outgoing_count = call_graph.get_callees(symbol_id).len() as f64;
+    
+    // Importance based on connectivity (more connections = more important)
+    // Root nodes (no incoming) get bonus importance
+    let root_bonus = if incoming_count == 0.0 && outgoing_count > 0.0 { 10.0 } else { 0.0 };
+    
+    // Leaf nodes (no outgoing) get slight penalty
+    let leaf_penalty = if outgoing_count == 0.0 && incoming_count > 0.0 { -2.0 } else { 0.0 };
+    
+    incoming_count + outgoing_count + root_bonus + leaf_penalty
+}
