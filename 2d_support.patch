@@ -0,0 +1,61 @@
+use super::*;
+use crate::geometry::Vector2D;
+use core_data::SymbolId;
+
+/// Node selection in 2D space
+pub fn find_node_at_position(
+    layout: &GridLayout,
+    world_x: f64,
+    world_y: f64,
+) -> Option<SymbolId> {
+    for (symbol_id, node) in &layout.nodes {
+        if is_point_in_node(world_x, world_y, node) {
+            return Some(symbol_id.clone());
+        }
+    }
+    None
+}
+
+/// Check if a point is inside a node's bounds
+pub fn is_point_in_node(x: f64, y: f64, node: &VisualNode) -> bool {
+    let half_width = node.width / 2.0;
+    let half_height = node.height / 2.0;
+    
+    x >= node.position.x - half_width
+        && x <= node.position.x + half_width
+        && y >= node.position.y - half_height
+        && y <= node.position.y + half_height
+}
+
+/// Find the closest node to a given position
+pub fn find_closest_node(
+    layout: &GridLayout,
+    world_x: f64,
+    world_y: f64,
+    max_distance: Option<f64>,
+) -> Option<(SymbolId, f64)> {
+    let mut closest: Option<(SymbolId, f64)> = None;
+    let point = Vector2D::new(world_x, world_y);
+    
+    for (symbol_id, node) in &layout.nodes {
+        let node_pos = Vector2D::new(node.position.x, node.position.y);
+        let distance = point.distance_to(&node_pos);
+        
+        if let Some(max_dist) = max_distance {
+            if distance > max_dist {
+                continue;
+            }
+        }
+        
+        match &closest {
+            None => closest = Some((symbol_id.clone(), distance)),
+            Some((_, closest_dist)) => {
+                if distance < *closest_dist {
+                    closest = Some((symbol_id.clone(), distance));
+                }
+            }
+        }
+    }
+    
+    closest
+}
diff --git a/tui_ui/src/canvas/smooth_lines.rs b/tui_ui/src/canvas/smooth_lines.rs
