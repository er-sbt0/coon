@@ -0,0 +1,163 @@
+use super::*;
+use crate::geometry::Vector2D;
+use ratatui::{
+    style::Color,
+    widgets::canvas::{Context, Points},
+};
+
+/// Smooth line renderer using dense points
+#[derive(Debug, Clone)]
+pub struct SmoothLine {
+    pub start: Vector2D,
+    pub end: Vector2D,
+    pub color: Color,
+    pub thickness: f32,
+}
+
+impl SmoothLine {
+    pub fn new(start: Vector2D, end: Vector2D, color: Color) -> Self {
+        Self {
+            start,
+            end,
+            color,
+            thickness: 1.0,
+        }
+    }
+    
+    pub fn with_thickness(mut self, thickness: f32) -> Self {
+        self.thickness = thickness;
+        self
+    }
+
+    /// Render smooth line using dense point sampling
+    pub fn render(&self, ctx: &mut Context) {
+        let points = self.calculate_line_points();
+        
+        // Use thickness to determine how many parallel lines to draw
+        let thickness_lines = (self.thickness.max(1.0) as usize).min(3);
+        
+        for i in 0..thickness_lines {
+            let offset = if thickness_lines == 1 {
+                0.0
+            } else {
+                (i as f64 - (thickness_lines - 1) as f64 / 2.0) * 0.5
+            };
+            
+            let offset_points: Vec<(f64, f64)> = points
+                .iter()
+                .map(|&(x, y)| {
+                    // Add small perpendicular offset for thickness
+                    let dx = self.end.x - self.start.x;
+                    let dy = self.end.y - self.start.y;
+                    let length = (dx * dx + dy * dy).sqrt();
+                    
+                    if length > 0.0 {
+                        let perp_x = -dy / length * offset;
+                        let perp_y = dx / length * offset;
+                        (x + perp_x, y + perp_y)
+                    } else {
+                        (x, y)
+                    }
+                })
+                .collect();
+            
+            let points_widget = Points {
+                coords: &offset_points,
+                color: self.color,
+            };
+            
+            ctx.draw(&points_widget);
+        }
+    }
+    
+    /// Calculate dense points along the line for smooth appearance
+    fn calculate_line_points(&self) -> Vec<(f64, f64)> {
+        let dx = self.end.x - self.start.x;
+        let dy = self.end.y - self.start.y;
+        let distance = (dx * dx + dy * dy).sqrt();
+        
+        if distance < 0.1 {
+            return vec![(self.start.x, self.start.y)];
+        }
+        
+        // Calculate number of points based on distance
+        // Use higher density for smooth appearance
+        let num_points = (distance * 2.0).max(2.0) as usize;
+        let mut points = Vec::with_capacity(num_points);
+        
+        for i in 0..=num_points {
+            let t = i as f64 / num_points as f64;
+            let x = self.start.x + t * dx;
+            let y = self.start.y + t * dy;
+            points.push((x, y));
+        }
+        
+        points
+    }
+}
+
+/// Enhanced edge rendering with smooth lines
+pub fn render_smooth_edges(ctx: &mut Context, layout: &GridLayout) {
+    for edge in &layout.edges {
+        if let (Some(from_node), Some(to_node)) = (
+            layout.nodes.get(&edge.from_symbol),
+            layout.nodes.get(&edge.to_symbol),
+        ) {
+            let start = Vector2D::new(from_node.position.x, from_node.position.y);
+            let end = Vector2D::new(to_node.position.x, to_node.position.y);
+            
+            let smooth_line = SmoothLine::new(start, end, edge.color)
+                .with_thickness(edge.weight);
+            
+            smooth_line.render(ctx);
+            
+            // Draw arrow head for directed edges
+            if matches!(edge.edge_type, EdgeType::Call) && layout.viewport.zoom_level > 1.0 {
+                draw_smooth_arrow_head(ctx, &start, &end, edge.color);
+            }
+        }
+    }
+}
+
+/// Draw a smooth arrow head using points
+fn draw_smooth_arrow_head(ctx: &mut Context, from: &Vector2D, to: &Vector2D, color: Color) {
+    let dx = to.x - from.x;
+    let dy = to.y - from.y;
+    let length = (dx * dx + dy * dy).sqrt();
+    
+    if length < 1.0 {
+        return;
+    }
+    
+    let unit_x = dx / length;
+    let unit_y = dy / length;
+    
+    let arrow_length = 3.0;
+    let arrow_width = 1.5;
+    
+    // Calculate arrow head points
+    let tip_x = to.x;
+    let tip_y = to.y;
+    
+    let base_x = tip_x - arrow_length * unit_x;
+    let base_y = tip_y - arrow_length * unit_y;
+    
+    let perp_x = -unit_y * arrow_width;
+    let perp_y = unit_x * arrow_width;
+    
+    // Create smooth arrow lines
+    let line1 = SmoothLine::new(
+        Vector2D::new(tip_x, tip_y),
+        Vector2D::new(base_x + perp_x, base_y + perp_y),
+        color,
+    );
+    
+    let line2 = SmoothLine::new(
+        Vector2D::new(tip_x, tip_y),
+        Vector2D::new(base_x - perp_x, base_y - perp_y),
+        color,
+    );
+    
+    line1.render(ctx);
+    line2.render(ctx);
+}
