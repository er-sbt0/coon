+2. **Hierarchical Layout Implementation** (`tui_ui/src/canvas/layout_algorithms.rs`):
+```rust
+pub struct HierarchicalLayout {
+    config: HierarchicalConfig,
+    layers: GraphLayers,
+}
+
+impl HierarchicalLayout {
+    pub fn calculate_layout(&mut self, call_graph: &CallGraph) -> GridLayout {
+        // Step 1: Analyze call hierarchy and assign layers
+        let root_nodes = self.find_root_nodes(call_graph);
+        self.layers = analyze_call_hierarchy(call_graph, &root_nodes);
+        
+        // Step 2: Position nodes layer by layer
+        let mut layout = GridLayout::new();
+        
+        for (layer_index, layer_nodes) in self.layers.layers.iter().enumerate() {
+            let x = layer_index as f64 * self.config.layer_spacing;
+            
+            // Distribute nodes vertically within the layer
+            let node_count = layer_nodes.len();
+            let total_height = (node_count - 1) as f64 * self.config.node_spacing;
+            let start_y = -total_height / 2.0;
+            
+            for (node_index, symbol_id) in layer_nodes.iter().enumerate() {
+                let y = start_y + node_index as f64 * self.config.node_spacing;
+                
+                let position = NodePosition::new(x, y);
+                let node = VisualNode::new(symbol_id.clone(), position)
+                    .with_color(self.get_layer_color(layer_index));
+                
+                layout.add_node(node);
+            }
+        }
+        
+        // Step 3: Add edges with proper routing
+        self.add_hierarchical_edges(&mut layout, call_graph);
+        
+        layout.center_viewport_on_bounds();
+        layout
+    }
+    
+    fn find_root_nodes(&self, call_graph: &CallGraph) -> Vec<SymbolId> {
+        // Find nodes with no incoming calls (entry points)
+        call_graph.nodes.keys()
+            .filter(|id| call_graph.get_callers(id).is_empty())
+            .cloned()
+            .collect()
+    }
+    
+    fn get_layer_color(&self, layer_index: usize) -> Color {
+        // Color gradient from left to right
+        match layer_index % 5 {
+            0 => Color::Red,     // Entry points
+            1 => Color::Yellow,  // First level
+            2 => Color::Blue,    // Second level
+            3 => Color::Green,   // Third level
+            _ => Color::Cyan,    // Deeper levels
+        }
+    }
+}
+```
