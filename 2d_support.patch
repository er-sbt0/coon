diff --git a/tui_ui/src/canvas/canvas_renderer.rs b/tui_ui/src/canvas/canvas_renderer.rs
new file mode 100644
index 0000000..51c98d6
--- /dev/null
+++ b/tui_ui/src/canvas/canvas_renderer.rs
@@ -0,0 +1,182 @@
+use super::*;
+use core_data::CallGraph;
+use ratatui::{
+    layout::Rect,
+    style::Color,
+    symbols::Marker,
+    widgets::{
+        canvas::{Canvas, Context, Line, Rectangle},
+        Block, Borders,
+    },
+    Frame,
+};
+
+/// Main canvas rendering function for the 2D call graph with text overlays
+pub fn render_canvas_with_labels(
+    f: &mut Frame,
+    area: Rect,
+    layout: &GridLayout,
+    call_graph: &CallGraph,
+    selected_function: Option<&core_data::SymbolId>,
+) -> Vec<(TextOverlay, Rect)> {
+    // Render canvas as before
+    render_canvas_call_graph(f, area, layout, call_graph, selected_function);
+    
+    // Calculate text overlay positions
+    calculate_text_overlays(layout, call_graph, &layout.viewport, area)
+}
+
+/// Main canvas rendering function for the 2D call graph
+pub fn render_canvas_call_graph(f: &mut Frame, area: Rect, layout: &GridLayout, _call_graph: &CallGraph, selected_function: Option<&core_data::SymbolId>) {
+    let viewport = &layout.viewport;
+    
+    let canvas = Canvas::default()
+        .block(
+            Block::default()
+                .borders(Borders::ALL)
+                .title(format!(
+                    "Call Graph - 2D View ({} nodes) - WASD/hjkl to pan, +/- to zoom, Space to center",
+                    layout.nodes.len()
+                ))
+        )
+        .paint(|ctx| {
+            // Render edges first (background) using smooth lines
+            render_smooth_edges(ctx, layout);
+            
+            // Render nodes (foreground)
+            render_nodes(ctx, layout, selected_function);
+        })
+        .marker(Marker::Braille) // High resolution
+        .x_bounds([
+            viewport.center_x - (area.width as f64 / viewport.zoom_level / 2.0),
+            viewport.center_x + (area.width as f64 / viewport.zoom_level / 2.0),
+        ])
+        .y_bounds([
+            viewport.center_y - (area.height as f64 / viewport.zoom_level / 2.0),
+            viewport.center_y + (area.height as f64 / viewport.zoom_level / 2.0),
+        ]);
+
+    f.render_widget(canvas, area);
+}
+
+/// Render all nodes in the layout
+fn render_nodes(ctx: &mut Context, layout: &GridLayout, selected: Option<&core_data::SymbolId>) {
+    for (symbol_id, visual_node) in &layout.nodes {
+        let color = if Some(symbol_id) == selected {
+            Color::Yellow
+        } else if visual_node.is_selected {
+            Color::White
+        } else {
+            visual_node.color
+        };
+        
+        // Draw node as rectangle
+        let rect = Rectangle {
+            x: visual_node.position.x - visual_node.width / 2.0,
+            y: visual_node.position.y - visual_node.height / 2.0,
+            width: visual_node.width,
+            height: visual_node.height,
+            color,
+        };
+        
+        ctx.draw(&rect);
+        
+        // Add selection highlight
+        if visual_node.is_selected || Some(symbol_id) == selected {
+            let highlight = Rectangle {
+                x: visual_node.position.x - visual_node.width / 2.0 - 1.0,
+                y: visual_node.position.y - visual_node.height / 2.0 - 1.0,
+                width: visual_node.width + 2.0,
+                height: visual_node.height + 2.0,
+                color: Color::White,
+            };
+            ctx.draw(&highlight);
+        }
+    }
+}
+
+/// Render all edges in the layout
+fn render_edges(ctx: &mut Context, layout: &GridLayout) {
+    for edge in &layout.edges {
+        if let (Some(from_node), Some(to_node)) = (
+            layout.nodes.get(&edge.from_symbol),
+            layout.nodes.get(&edge.to_symbol),
+        ) {
+            let line = Line {
+                x1: from_node.position.x,
+                y1: from_node.position.y,
+                x2: to_node.position.x,
+                y2: to_node.position.y,
+                color: edge.color,
+            };
+            
+            ctx.draw(&line);
+            
+            // Optional: Draw arrow heads for directed edges
+            if matches!(edge.edge_type, EdgeType::Call) && layout.viewport.zoom_level > 1.0 {
+                draw_arrow_head(ctx, &from_node.position, &to_node.position, edge.color);
+            }
+        }
+    }
+}
+
+/// Render node labels (when zoomed in enough)
+fn render_labels(ctx: &mut Context, layout: &GridLayout, call_graph: &CallGraph) {
+    for (symbol_id, visual_node) in &layout.nodes {
+        if let Some(function_node) = call_graph.nodes.get(symbol_id) {
+            // Simple label - just show function name
+            let label_text = function_node.name.clone();
+            
+            // For now, we'll skip text rendering as it's complex in canvas
+            // This would be enhanced in future iterations
+            let _ = (label_text, &*ctx, visual_node);
+        }
+    }
+}
+
+/// Draw an arrow head at the end of an edge
+fn draw_arrow_head(ctx: &mut Context, from: &NodePosition, to: &NodePosition, color: Color) {
+    let dx = to.x - from.x;
+    let dy = to.y - from.y;
+    let length = (dx * dx + dy * dy).sqrt();
+    
+    if length < 1.0 {
+        return;
+    }
+    
+    let unit_x = dx / length;
+    let unit_y = dy / length;
+    
+    let arrow_length = 2.0;
+    let arrow_width = 1.0;
+    
+    // Calculate arrow head points
+    let tip_x = to.x;
+    let tip_y = to.y;
+    
+    let base_x = tip_x - arrow_length * unit_x;
+    let base_y = tip_y - arrow_length * unit_y;
+    
+    let perp_x = -unit_y * arrow_width;
+    let perp_y = unit_x * arrow_width;
+    
+    // Draw arrow head lines
+    let line1 = Line {
+        x1: tip_x,
+        y1: tip_y,
+        x2: base_x + perp_x,
+        y2: base_y + perp_y,
+        color,
+    };
+    
+    let line2 = Line {
+        x1: tip_x,
+        y1: tip_y,
+        x2: base_x - perp_x,
+        y2: base_y - perp_y,
+        color,
+    };
+    
+    ctx.draw(&line1);
+    ctx.draw(&line2);
+}
