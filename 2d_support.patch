+                y: visual_node.position.y - visual_node.height / 2.0 - 1.0,
+                width: visual_node.width + 2.0,
+                height: visual_node.height + 2.0,
+                color: Color::White,
+            };
+            ctx.draw(&highlight);
+        }
+    }
+}
