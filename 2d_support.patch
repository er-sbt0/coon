@@ -0,0 +1,40 @@
+use super::{Bounds, Vector2D};
+
+/// Check if a point is inside a rectangular area
+pub fn point_in_rect(point: &Vector2D, center: &Vector2D, width: f64, height: f64) -> bool {
+    let bounds = Bounds::from_center(center.x, center.y, width, height);
+    bounds.contains_point(point.x, point.y)
+}
+
+/// Find the closest point on a rectangle to a given point
+pub fn closest_point_on_rect(
+    point: &Vector2D,
+    rect_center: &Vector2D,
+    width: f64,
+    height: f64,
+) -> Vector2D {
+    let half_width = width / 2.0;
+    let half_height = height / 2.0;
+
+    let clamped_x = point.x.clamp(
+        rect_center.x - half_width,
+        rect_center.x + half_width,
+    );
+    let clamped_y = point.y.clamp(
+        rect_center.y - half_height,
+        rect_center.y + half_height,
+    );
+
+    Vector2D::new(clamped_x, clamped_y)
+}
+
+/// Calculate distance from a point to a rectangle
+pub fn distance_to_rect(
+    point: &Vector2D,
+    rect_center: &Vector2D,
+    width: f64,
+    height: f64,
+) -> f64 {
+    let closest = closest_point_on_rect(point, rect_center, width, height);
+    point.distance_to(&closest)
+}
