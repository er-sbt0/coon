@@ -0,0 +1,221 @@
+use super::*;
+use crate::geometry::Vector2D;
+
+/// Edge routing for different layout types
+pub fn route_hierarchical_edge(
+    from_node: &VisualNode,
+    to_node: &VisualNode,
+    config: &HierarchicalConfig,
+) -> Vec<Vector2D> {
+    match config.direction {
+        LayoutDirection::LeftRight => route_left_right_edge(from_node, to_node),
+        LayoutDirection::RightLeft => route_right_left_edge(from_node, to_node),
+        LayoutDirection::TopDown => route_top_down_edge(from_node, to_node),
+        LayoutDirection::BottomUp => route_bottom_up_edge(from_node, to_node),
+    }
+}
+
+/// Route edge for left-to-right layout
+fn route_left_right_edge(from_node: &VisualNode, to_node: &VisualNode) -> Vec<Vector2D> {
+    // Start from right edge of source node
+    let start_x = from_node.position.x + from_node.width / 2.0;
+    let start_y = from_node.position.y;
+    
+    // End at left edge of target node
+    let end_x = to_node.position.x - to_node.width / 2.0;
+    let end_y = to_node.position.y;
+    
+    // If target is to the right, use direct connection
+    if end_x > start_x {
+        vec![
+            Vector2D::new(start_x, start_y),
+            Vector2D::new(end_x, end_y),
+        ]
+    } else {
+        // Target is to the left or same column - use curved routing
+        route_curved_edge(start_x, start_y, end_x, end_y)
+    }
+}
+
+/// Route edge for right-to-left layout
+fn route_right_left_edge(from_node: &VisualNode, to_node: &VisualNode) -> Vec<Vector2D> {
+    // Start from left edge of source node
+    let start_x = from_node.position.x - from_node.width / 2.0;
+    let start_y = from_node.position.y;
+    
+    // End at right edge of target node
+    let end_x = to_node.position.x + to_node.width / 2.0;
+    let end_y = to_node.position.y;
+    
+    // If target is to the left, use direct connection
+    if end_x < start_x {
+        vec![
+            Vector2D::new(start_x, start_y),
+            Vector2D::new(end_x, end_y),
+        ]
+    } else {
+        // Target is to the right or same column - use curved routing
+        route_curved_edge(start_x, start_y, end_x, end_y)
+    }
+}
+
+/// Route edge for top-down layout
+fn route_top_down_edge(from_node: &VisualNode, to_node: &VisualNode) -> Vec<Vector2D> {
+    // Start from bottom edge of source node
+    let start_x = from_node.position.x;
+    let start_y = from_node.position.y + from_node.height / 2.0;
+    
+    // End at top edge of target node
+    let end_x = to_node.position.x;
+    let end_y = to_node.position.y - to_node.height / 2.0;
+    
+    // If target is below, use direct connection
+    if end_y > start_y {
+        vec![
+            Vector2D::new(start_x, start_y),
+            Vector2D::new(end_x, end_y),
+        ]
+    } else {
+        // Target is above or same row - use curved routing
+        route_curved_edge(start_x, start_y, end_x, end_y)
+    }
+}
+
+/// Route edge for bottom-up layout
+fn route_bottom_up_edge(from_node: &VisualNode, to_node: &VisualNode) -> Vec<Vector2D> {
+    // Start from top edge of source node
+    let start_x = from_node.position.x;
+    let start_y = from_node.position.y - from_node.height / 2.0;
+    
+    // End at bottom edge of target node
+    let end_x = to_node.position.x;
+    let end_y = to_node.position.y + to_node.height / 2.0;
+    
+    // If target is above, use direct connection
+    if end_y < start_y {
+        vec![
+            Vector2D::new(start_x, start_y),
+            Vector2D::new(end_x, end_y),
+        ]
+    } else {
+        // Target is below or same row - use curved routing
+        route_curved_edge(start_x, start_y, end_x, end_y)
+    }
+}
+
+/// Route curved edge to avoid overlap
+fn route_curved_edge(start_x: f64, start_y: f64, end_x: f64, end_y: f64) -> Vec<Vector2D> {
+    let mid_x = (start_x + end_x) / 2.0;
+    let mid_y = (start_y + end_y) / 2.0;
+    
+    // Add curve points for smoother appearance
+    let control_offset = 20.0;
+    
+    vec![
+        Vector2D::new(start_x, start_y),
+        Vector2D::new(start_x + control_offset, start_y),
+        Vector2D::new(mid_x, mid_y),
+        Vector2D::new(end_x - control_offset, end_y),
+        Vector2D::new(end_x, end_y),
+    ]
+}
+
+/// Route edge with bezier curve
+pub fn route_bezier_edge(
+    from_node: &VisualNode,
+    to_node: &VisualNode,
+    control_strength: f64,
+) -> Vec<Vector2D> {
+    let start = Vector2D::new(from_node.position.x, from_node.position.y);
+    let end = Vector2D::new(to_node.position.x, to_node.position.y);
+    
+    // Calculate control points
+    let direction = end.subtract(&start);
+    let distance = direction.magnitude();
+    let control_distance = distance * control_strength;
+    
+    let control1 = start.add(&direction.normalize().scale(control_distance * 0.3));
+    let control2 = end.subtract(&direction.normalize().scale(control_distance * 0.3));
+    
+    // Generate bezier curve points
+    bezier_curve_points(&start, &control1, &control2, &end, 20)
+}
+
+/// Generate points along a cubic bezier curve
+fn bezier_curve_points(
+    p0: &Vector2D,
+    p1: &Vector2D,
+    p2: &Vector2D,
+    p3: &Vector2D,
+    num_points: usize,
+) -> Vec<Vector2D> {
+    let mut points = Vec::with_capacity(num_points);
+    
+    for i in 0..=num_points {
+        let t = i as f64 / num_points as f64;
+        let point = cubic_bezier_point(p0, p1, p2, p3, t);
+        points.push(point);
+    }
+    
+    points
+}
+
+/// Calculate point on cubic bezier curve at parameter t
+fn cubic_bezier_point(
+    p0: &Vector2D,
+    p1: &Vector2D,
+    p2: &Vector2D,
+    p3: &Vector2D,
+    t: f64,
+) -> Vector2D {
+    let u = 1.0 - t;
+    let tt = t * t;
+    let uu = u * u;
+    let uuu = uu * u;
+    let ttt = tt * t;
+    
+    let mut point = p0.scale(uuu);
+    point = point.add(&p1.scale(3.0 * uu * t));
+    point = point.add(&p2.scale(3.0 * u * tt));
+    point.add(&p3.scale(ttt))
+}
+
+/// Check if two edges would visually overlap
+pub fn edges_overlap(
+    edge1_start: &Vector2D,
+    edge1_end: &Vector2D,
+    edge2_start: &Vector2D,
+    edge2_end: &Vector2D,
+    threshold: f64,
+) -> bool {
+    // Simple check: if edges are very close and parallel
+    let dist1 = point_to_line_distance(edge1_start, edge2_start, edge2_end);
+    let dist2 = point_to_line_distance(edge1_end, edge2_start, edge2_end);
+    
+    (dist1 < threshold && dist2 < threshold) || 
+    (point_to_line_distance(edge2_start, edge1_start, edge1_end) < threshold &&
+     point_to_line_distance(edge2_end, edge1_start, edge1_end) < threshold)
+}
+
+/// Calculate distance from point to line segment
+fn point_to_line_distance(point: &Vector2D, line_start: &Vector2D, line_end: &Vector2D) -> f64 {
+    let line_vec = line_end.subtract(line_start);
+    let point_vec = point.subtract(line_start);
+    
+    let line_length = line_vec.magnitude();
+    if line_length < 0.001 {
+        return point_vec.magnitude();
+    }
+    
+    let line_unit = line_vec.scale(1.0 / line_length);
+    let projection = point_vec.dot(&line_unit);
+    
+    if projection <= 0.0 {
+        point_vec.magnitude()
+    } else if projection >= line_length {
+        point.subtract(line_end).magnitude()
+    } else {
+        let closest_point = line_start.add(&line_unit.scale(projection));
+        point.subtract(&closest_point).magnitude()
+    }
+}
