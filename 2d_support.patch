+            app.canvas_viewport.center_x + (area.width as f64 / app.canvas_viewport.zoom_level / 2.0),
+        ])
+        .y_bounds([
+            app.canvas_viewport.center_y - (area.height as f64 / app.canvas_viewport.zoom_level / 2.0),
+            app.canvas_viewport.center_y + (area.height as f64 / app.canvas_viewport.zoom_level / 2.0),
