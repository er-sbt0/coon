@@ -0,0 +1,43 @@
+use super::*;
+
+/// View modes for the 2D graph
+#[derive(Debug, Clone, PartialEq)]
+pub enum ViewMode {
+    Overview,      // Show all nodes
+    Focused,       // Center on selected function with neighbors
+    Path,          // Show path between two functions
+    Cluster,       // Show logical clusters/modules
+}
+
+impl Default for ViewMode {
+    fn default() -> Self {
+        ViewMode::Overview
+    }
+}
+
+/// Viewport management for 2D navigation
+impl Viewport {
+    pub fn get_bounds_for_area(&self, area_width: u16, area_height: u16) -> (f64, f64, f64, f64) {
+        let width_world = area_width as f64 / self.zoom_level;
+        let height_world = area_height as f64 / self.zoom_level;
+        
+        let min_x = self.center_x - width_world / 2.0;
+        let max_x = self.center_x + width_world / 2.0;
+        let min_y = self.center_y - height_world / 2.0;
+        let max_y = self.center_y + height_world / 2.0;
+        
+        (min_x, min_y, max_x, max_y)
+    }
+
+    pub fn world_to_screen(&self, world_x: f64, world_y: f64, area_width: u16, area_height: u16) -> (f64, f64) {
+        let screen_x = (world_x - self.center_x) * self.zoom_level + (area_width as f64 / 2.0);
+        let screen_y = (world_y - self.center_y) * self.zoom_level + (area_height as f64 / 2.0);
+        (screen_x, screen_y)
+    }
+
+    pub fn screen_to_world(&self, screen_x: f64, screen_y: f64, area_width: u16, area_height: u16) -> (f64, f64) {
+        let world_x = (screen_x - area_width as f64 / 2.0) / self.zoom_level + self.center_x;
+        let world_y = (screen_y - area_height as f64 / 2.0) / self.zoom_level + self.center_y;
+        (world_x, world_y)
+    }
+}
diff --git a/tui_ui/src/canvas/visual_elements.rs b/tui_ui/src/canvas/visual_elements.rs
new file mode 100644
index 0000000..a85de3c
--- /dev/null
+++ b/tui_ui/src/canvas/visual_elements.rs
@@ -0,0 +1,240 @@
+use core_data::SymbolId;
+use ratatui::style::Color;
+use std::collections::HashMap;
+
+use crate::geometry::Vector2D;
+
+/// Position of a node in 2D space
+#[derive(Debug, Clone, PartialEq)]
+pub struct NodePosition {
+    pub x: f64,
+    pub y: f64,
+}
+
+impl NodePosition {
+    pub fn new(x: f64, y: f64) -> Self {
+        Self { x, y }
+    }
+
+    pub fn to_vector(&self) -> Vector2D {
+        Vector2D::new(self.x, self.y)
+    }
+
+    pub fn from_vector(v: &Vector2D) -> Self {
+        Self::new(v.x, v.y)
+    }
+}
+
+impl Default for NodePosition {
+    fn default() -> Self {
+        Self::new(0.0, 0.0)
+    }
+}
+
+/// Visual representation of a node in the 2D graph
+#[derive(Debug, Clone)]
+pub struct VisualNode {
+    pub symbol_id: SymbolId,
+    pub position: NodePosition,
+    pub width: f64,
+    pub height: f64,
+    pub is_selected: bool,
+    pub is_highlighted: bool,
+    pub color: Color,
+}
+
+impl VisualNode {
+    pub fn new(symbol_id: SymbolId, position: NodePosition) -> Self {
+        Self {
+            symbol_id,
+            position,
+            width: 8.0,
+            height: 4.0,
+            is_selected: false,
+            is_highlighted: false,
+            color: Color::Blue,
+        }
+    }
+
+    pub fn with_size(mut self, width: f64, height: f64) -> Self {
+        self.width = width;
+        self.height = height;
+        self
+    }
+
+    pub fn with_color(mut self, color: Color) -> Self {
+        self.color = color;
+        self
+    }
+}
+
+/// Types of edges in the graph
+#[derive(Debug, Clone, PartialEq)]
+pub enum EdgeType {
+    Call,
+    Reference,
+    Inheritance,
+    Dependency,
+}
+
+/// Visual representation of an edge between nodes
+#[derive(Debug, Clone)]
+pub struct VisualEdge {
+    pub from_symbol: SymbolId,
+    pub to_symbol: SymbolId,
+    pub edge_type: EdgeType,
+    pub color: Color,
+    pub weight: f32, // For line thickness
+}
+
+impl VisualEdge {
+    pub fn new(from_symbol: SymbolId, to_symbol: SymbolId, edge_type: EdgeType) -> Self {
+        Self {
+            from_symbol,
+            to_symbol,
+            edge_type,
+            color: Color::Gray,
+            weight: 1.0,
+        }
+    }
+
+    pub fn with_color(mut self, color: Color) -> Self {
+        self.color = color;
+        self
+    }
+
+    pub fn with_weight(mut self, weight: f32) -> Self {
+        self.weight = weight;
+        self
+    }
+}
+
+/// Viewport configuration for the 2D canvas
+#[derive(Debug, Clone)]
+pub struct Viewport {
+    pub center_x: f64,
+    pub center_y: f64,
+    pub zoom_level: f64,
+}
+
+impl Viewport {
+    pub fn new() -> Self {
+        Self {
+            center_x: 0.0,
+            center_y: 0.0,
+            zoom_level: 1.0,
+        }
+    }
+
+    pub fn pan(&mut self, dx: f64, dy: f64) {
+        self.center_x += dx / self.zoom_level;
+        self.center_y += dy / self.zoom_level;
+    }
+
+    pub fn zoom(&mut self, factor: f64) {
+        self.zoom_level = (self.zoom_level * factor).clamp(0.1, 10.0);
+    }
+
+    pub fn center_on(&mut self, x: f64, y: f64) {
+        self.center_x = x;
+        self.center_y = y;
+    }
+
+    pub fn reset(&mut self) {
+        self.center_x = 0.0;
+        self.center_y = 0.0;
+        self.zoom_level = 1.0;
+    }
+}
+
+impl Default for Viewport {
+    fn default() -> Self {
+        Self::new()
+    }
+}
+
+/// Complete 2D layout of the graph
+#[derive(Debug, Clone)]
+pub struct GridLayout {
+    pub nodes: HashMap<SymbolId, VisualNode>,
+    pub edges: Vec<VisualEdge>,
+    pub viewport: Viewport,
+    pub bounds: (f64, f64, f64, f64), // min_x, min_y, max_x, max_y
+}
+
+impl GridLayout {
+    pub fn new() -> Self {
+        Self {
+            nodes: HashMap::new(),
+            edges: Vec::new(),
+            viewport: Viewport::new(),
+            bounds: (0.0, 0.0, 0.0, 0.0),
+        }
+    }
+
+    pub fn add_node(&mut self, node: VisualNode) {
+        self.nodes.insert(node.symbol_id.clone(), node);
+        self.update_bounds();
+    }
+
+    pub fn add_edge(&mut self, edge: VisualEdge) {
+        self.edges.push(edge);
+    }
+
+    pub fn get_node_mut(&mut self, symbol_id: &SymbolId) -> Option<&mut VisualNode> {
+        self.nodes.get_mut(symbol_id)
+    }
+
+    pub fn select_node(&mut self, symbol_id: &SymbolId) {
+        // Deselect all nodes first
+        for node in self.nodes.values_mut() {
+            node.is_selected = false;
+        }
+        
+        // Select the target node
+        if let Some(node) = self.nodes.get_mut(symbol_id) {
+            node.is_selected = true;
+        }
+    }
+
+    pub fn update_bounds(&mut self) {
+        if self.nodes.is_empty() {
+            self.bounds = (0.0, 0.0, 0.0, 0.0);
+            return;
+        }
+
+        let mut min_x = f64::INFINITY;
+        let mut max_x = f64::NEG_INFINITY;
+        let mut min_y = f64::INFINITY;
+        let mut max_y = f64::NEG_INFINITY;
+
+        for node in self.nodes.values() {
+            let half_width = node.width / 2.0;
+            let half_height = node.height / 2.0;
+            
+            min_x = min_x.min(node.position.x - half_width);
+            max_x = max_x.max(node.position.x + half_width);
+            min_y = min_y.min(node.position.y - half_height);
+            max_y = max_y.max(node.position.y + half_height);
+        }
+
+        self.bounds = (min_x, min_y, max_x, max_y);
+    }
+
+    pub fn center_viewport_on_bounds(&mut self) {
+        let (min_x, min_y, max_x, max_y) = self.bounds;
+        self.viewport.center_on((min_x + max_x) / 2.0, (min_y + max_y) / 2.0);
+    }
+    
+    pub fn get_selected_node(&self) -> Option<&SymbolId> {
+        self.nodes.iter()
+            .find(|(_, node)| node.is_selected)
+            .map(|(id, _)| id)
+    }
+}
